# Supabase Storage Configuration
# Used for signed URL helpers and browser-side image uploads.
# PDF uploads are handled by backend service-role storage writes.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL (optional, defaults to http://localhost:8000)
VITE_API_BASE=http://localhost:8000

# Base path for Vite build/dev.
# Local dev: "/"
# Reverse-proxy deployment (platform): "/caliber/"
VITE_BASE_PATH=/

# Optional absolute portal URL for login/logout redirects when frontend is served
# from a different origin than the portal (e.g. local dev server).
# Example: http://localhost
VITE_PORTAL_BASE_URL=

# Optional direct Keycloak/OIDC mode for local dev (recommended when running
# frontend on :5173 and backend on :8000 without the full portal reverse proxy).
# When set, the frontend performs PKCE login and sends Bearer tokens directly.
# Example:
# VITE_OIDC_ISSUER=https://app.caliber.cs.ucsb.edu/auth/realms/platform
VITE_OIDC_ISSUER=
VITE_OIDC_CLIENT_ID=portal
VITE_OIDC_SCOPES=openid profile email
# Optional overrides:
# VITE_OIDC_REDIRECT_URI=http://localhost:5173/
# VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/?logged_out=1
