# Database URL (PostgreSQL)
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/caliber

# For SQLite (For LOCAL Testing: Comment out line 2, uncomment line 5):
# DATABASE_URL=sqlite:///./data/questionbank.db

# Keycloak/OIDC Configuration
OIDC_ISSUER=http://localhost:8080/realms/platform
OIDC_JWKS_URL=
OIDC_AUDIENCE=

# Upload directory
UPLOAD_DIR=uploads

# Optional free local LLM cleanup (Ollama)
# Set true to format extracted text into cleaner Markdown.
LLM_CLEANUP_ENABLED=false
# For Dockerized backend, host.docker.internal reaches the Docker host's Ollama daemon.
LLM_CLEANUP_BASE_URL=http://host.docker.internal:11434
LLM_CLEANUP_MODEL=llama3.1:8b
LLM_CLEANUP_TIMEOUT_SEC=45

# Optional roster-service source-of-truth integration for user/course management.
ROSTER_BASE_URL=http://localhost:8000
ROSTER_MANAGEMENT_ENABLED=false
ROSTER_INTERNAL_SECRET=change-me
ROSTER_TIMEOUT_SEC=10
