# Database URL (Copy and replace with your Supabase database connection string)
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/caliber

# Keycloak/OIDC Configuration
OIDC_ISSUER=http://localhost:8080/realms/platform
OIDC_JWKS_URL=
OIDC_AUDIENCE=

# Supabase Storage (required for PDF uploads)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_PDF_BUCKET=question-pdfs
SUPABASE_STORAGE_TIMEOUT_SEC=25
M2_TESSERACT_TIMEOUT_SEC=45
M2_RENDER_DPI=170

# PDF parser selection.
# - odl  (default): opendataloader-pdf (Java 11+ required, Apache-2.0).
# - m2:             legacy Detectron2/EfficientDet + Tesseract pipeline.
PDF_PARSER=odl
# Route complex/scanned pages through the opendataloader-pdf hybrid backend
# (requires `opendataloader-pdf-hybrid --port 5002` running locally).
ODL_HYBRID_ENABLED=false
ODL_HYBRID_URL=http://127.0.0.1:5002
ODL_OCR_LANG=eng
ODL_TIMEOUT_SEC=120

# Upload directory
UPLOAD_DIR=uploads

# Optional free local LLM cleanup (Ollama)
# Set true to format extracted text into cleaner Markdown.
LLM_CLEANUP_ENABLED=false
LLM_CLEANUP_BASE_URL=http://127.0.0.1:11434
LLM_CLEANUP_MODEL=llama3.1:8b
# Optional fallback models if primary is unavailable (comma-separated).
# Example: qwen2.5:14b,qwen2.5:7b
LLM_CLEANUP_MODEL_FALLBACKS=
LLM_CLEANUP_TIMEOUT_SEC=45
# Force LLM pass on every extracted question (slower, but more consistent formatting).
LLM_CLEANUP_FORCE=false
# Optional path to custom markdown style guide instructions.
LLM_CLEANUP_STYLE_GUIDE_PATH=
# Enable backend logs for LLM formatter calls and guardrail decisions.
LLM_CLEANUP_DEBUG=false

# Variant generation LLM.
# Use gemini for the free Gemini API tier, or openrouter for the original Milestone 2 provider.
VARIANT_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Optional: set false/0 to force text-only generation even if a question has image crops.
VARIANT_LLM_VISION=true
# Optional fallback if you switch VARIANT_LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

ROSTER_MANAGEMENT_ENABLED=false
ROSTER_BASE_URL=http://localhost:8000/roster
ROSTER_INTERNAL_SECRET=change-me
ROSTER_TIMEOUT_SEC=10

# Coding runner integration
# Localhost dev:
# - leave CODING_RUNNER_URL unset/blank
# - backend will use the built-in local executor
# Server / Docker:
# - set CODING_RUNNER_URL to the runner service hostname, e.g. http://coding-runner:8010
CODING_RUNNER_URL=

# Runner-only settings
# Set true on the dedicated coding-runner service if you want each execution to happen
# inside a fresh short-lived Docker container. Leave false for local dev.
CODING_RUNNER_USE_DOCKER=false
CODING_RUNNER_CPP_IMAGE=gcc:14
