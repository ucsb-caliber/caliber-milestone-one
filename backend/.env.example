# Database URL (Copy and replace with your Supabase database connection string)
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/caliber

# Keycloak/OIDC Configuration
OIDC_ISSUER=http://localhost:8080/realms/platform
OIDC_JWKS_URL=
OIDC_AUDIENCE=

# Supabase Storage (required for PDF uploads)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_STORAGE_PDF_BUCKET=question-pdfs
SUPABASE_STORAGE_TIMEOUT_SEC=25
M2_TESSERACT_TIMEOUT_SEC=45
M2_RENDER_DPI=170

# Upload directory
UPLOAD_DIR=uploads

# Optional free local LLM cleanup (Ollama)
# Set true to format extracted text into cleaner Markdown.
LLM_CLEANUP_ENABLED=false
LLM_CLEANUP_BASE_URL=http://127.0.0.1:11434
LLM_CLEANUP_MODEL=llama3.1:8b
# Optional fallback models if primary is unavailable (comma-separated).
# Example: qwen2.5:14b,qwen2.5:7b
LLM_CLEANUP_MODEL_FALLBACKS=
LLM_CLEANUP_TIMEOUT_SEC=45
# Force LLM pass on every extracted question (slower, but more consistent formatting).
LLM_CLEANUP_FORCE=false
# Optional path to custom markdown style guide instructions.
LLM_CLEANUP_STYLE_GUIDE_PATH=
# Enable backend logs for LLM formatter calls and guardrail decisions.
LLM_CLEANUP_DEBUG=false

ROSTER_MANAGEMENT_ENABLED=false
ROSTER_BASE_URL=http://localhost:8000/roster
ROSTER_INTERNAL_SECRET=change-me
ROSTER_TIMEOUT_SEC=10
